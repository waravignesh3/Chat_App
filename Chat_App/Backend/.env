NODE_ENV=production
PORT=10000

# MySQL Database Configuration (REQUIRED on production)
# Set DATABASE_URL in your deployment platform (Render, Railway, etc.) environment variables
# Format: mysql://username:password@hostname:port/database
# Example: mysql://admin:mypassword@db.planetscale.com:3306/chatapp?ssl={"rejectUnauthorized":true}

# These are ONLY for local development - production should use DATABASE_URL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# Client URLs (comma-separated for CORS)
CLIENT_URLS=https://chat-app-kappa-blush-85.vercel.app,https://your-frontend-domain.com

# Server URL (backend URL used by frontend)
VITE_SERVER_URL=https://chat-app-1-m9cw.onrender.com
