NODE_ENV=production
PORT=10000

# ─── Option A: Single connection string (Render / Railway / PlanetScale) ───
# Uncomment and fill this in for production — takes priority over DB_* vars
# DATABASE_URL=mysql://username:password@hostname:3306/chatapp

# ─── Option B: Individual vars (local dev or AWS RDS) ─────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=chatapp
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# ─── CORS: comma-separated list of allowed frontend URLs ──────────────────
CLIENT_URLS=https://chat-app-kappa-blush-85.vercel.app,http://localhost:5173

# ─── Frontend env var (goes in frontend .env, not backend) ────────────────
# VITE_SERVER_URL=https://chat-app-1-m9cw.onrender.com