# Backend Configuration Template

# Environment (development | production)
NODE_ENV=development
PORT=5000

# MySQL Database Configuration
# Option 1: Individual parameters (for local development)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=chatapp
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# Option 2: Single DATABASE_URL (for production services like Render, Railway, etc.)
# Format: mysql://username:password@hostname:port/database
# Uncomment and set this for production, it takes precedence over individual DB_* variables
# DATABASE_URL=mysql://user:password@host:3306/chatapp

# Client URLs (comma-separated for CORS)
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,your-frontend-url.com

# Server URL (for client-side configuration)
VITE_SERVER_URL=http://localhost:5000
