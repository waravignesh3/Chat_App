# ── Backend Environment Variables ─────────────────────────────────────────────
# Copy this to .env and fill in your values. Never commit .env to version control.

# Server
PORT=5000
NODE_ENV=production

# CORS — comma-separated list of allowed frontend origins
CLIENT_URLS=https://your-frontend-domain.com

# Database (use DATABASE_URL OR the individual DB_* vars, not both)
DATABASE_URL=mysql://user:password@host:3306/chatapp

# OR use individual vars:
# DB_HOST=your-db-host
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
# DB_NAME=chatapp
# DB_PORT=3306
# DB_CONNECTION_LIMIT=10

# Set to "true" if your DB host requires SSL (e.g. PlanetScale, Aiven, Railway)
DB_SSL=true
